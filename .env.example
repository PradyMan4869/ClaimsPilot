# Copy to .env and adjust.

# LM Studio (Developer tab -> Start Server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_API_KEY=lm-studio

# MongoDB Community (optional — in-memory fallback is used when unreachable)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=claimspilot

# LangSmith free tier (leave LANGSMITH_TRACING=false to disable)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=claimspilot

# Agent endpoints
EXTRACTOR_PORT=8101
VALIDATOR_PORT=8102
RESPONDER_PORT=8103
AGENT_HOST=127.0.0.1

# CrewAI inside the Validator (falls back to deterministic pipeline when false)
CREWAI_ENABLED=false

# Business rules
AUTO_APPROVE_LIMIT=10000
